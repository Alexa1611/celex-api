# Copia este archivo como "yugabyte.env" y llena tus datos.
# NO subas yugabyte.env a GitHub.

# YugabyteDB
YUGABYTE_JDBC_URL=jdbc:postgresql://TU_HOST.aws.yugabyte.cloud:5433/yugabyte?sslmode=require
YUGABYTE_DB_USER=admin
YUGABYTE_DB_PASSWORD=pon_aqui_la_contraseña_del_credentials_txt

# SMTP Gmail (usa contraseña de aplicacion, NO la de tu cuenta)
# 1. Cuenta Google -> Seguridad -> Verificacion en 2 pasos (activar)
# 2. Seguridad -> Contraseñas de aplicaciones -> generar una para "Correo"
MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=tu_correo@gmail.com
MAIL_FROM_NAME=CELEX_FALSO

# Brevo API (produccion en Render; Render free bloquea SMTP)
BREVO_API_KEY=
